# PyTorch MPS DDPM configuration — copy this file to .env.pytorch and set your values.
# READ BY: src/ddpm_pytorch.py ONLY — intentionally separate from .env (MLX)
# This separation allows both scripts to run concurrently without variable conflicts.

# ── Paths ─────────────────────────────────────────────────────────────────────
# Set to the absolute path of the project root on your machine.
# If unset, defaults to the project root (parent of src/)
BASE_DIR=/path/to/your/mvp2-ddpm-cifar10

# ── Benchmark identity ────────────────────────────────────────────────────────
MACHINE_LABEL=My Machine          # shown in the benchmark card header
SAMPLE_SUBDIR=pytorch             # samples save to samples/<SAMPLE_SUBDIR>/
BENCH_FILE=benchmark_pytorch.txt  # output filename in benchmark_results/

# ── Training ──────────────────────────────────────────────────────────────────
NUM_EPOCHS=50
BATCH_SIZE=128        # reduce to 64 if you hit memory limits
LEARNING_RATE=0.0002

# ── Noise schedule ────────────────────────────────────────────────────────────
T=1000
BETA_START=0.0001
BETA_END=0.02

# ── DataLoader ────────────────────────────────────────────────────────────────
# Recommended: 4 for Apple Silicon with local data
# Use 0 if you experience multiprocessing spawn errors (e.g. data on external volume)
NUM_WORKERS=4
