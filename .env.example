# MLX DDPM configuration — copy this file to .env and set your values.
# READ BY: src/ddpm_mlx.py ONLY

# ── Paths ─────────────────────────────────────────────────────────────────────
# Set to the absolute path of the project root on your machine.
# If unset, defaults to the project root (parent of src/)
BASE_DIR=/path/to/your/mvp2-ddpm-cifar10

# ── Training ──────────────────────────────────────────────────────────────────
NUM_EPOCHS=50
BATCH_SIZE=128        # reduce to 64 if you hit memory limits
LEARNING_RATE=0.0002
NUM_WORKERS=0         # 0 = main process only; safe default on macOS

# ── Noise schedule ────────────────────────────────────────────────────────────
T=1000
BETA_START=0.0001
BETA_END=0.02
